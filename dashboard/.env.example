# Copy to .env.local and fill in.

# Supabase Postgres (session pooler) connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Supabase Storage — clients upload screenshots + transcripts directly here
# after a session is registered. The API route hands these values back to the
# client in the POST /api/sessions response.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-or-service-role-key
SUPABASE_BUCKET=recordings
